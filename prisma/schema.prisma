generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile        UserProfile?
  jobApplications JobApplication[]
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName        String?
  headline        String?
  phone           String?
  location        String?

  resumeText      String?
  cvFileUrl       String?
  linkedinUrl     String?

  parsedSkills    Json?
  experienceLevel String?
  targetLocation  String?

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model JobApplication {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  company     String
  location    String?
  url         String?
  matchPercent Int?
  reasoning   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
}
