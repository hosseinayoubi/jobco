{
  "version": 2,
  "buildCommand": "prisma generate && vite build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30,
      "includeFiles": "server/**,shared/**,prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path].ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
